{
  "name": "sht-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:customer": "turbo run dev --filter=@sht/customer",
    "dev:manager": "turbo run dev --filter=@sht/manager",
    "dev:quote": "turbo run dev --filter=@sht/quote",
    "sync:pull": "powershell -ExecutionPolicy Bypass -File scripts/workstation-sync.ps1 -Mode pull -AutoStash",
    "sync:mcp": "powershell -ExecutionPolicy Bypass -File scripts/workstation-sync.ps1 -Mode mcp-only",
    "sync:laptop": "powershell -ExecutionPolicy Bypass -File scripts/apply-laptop-once.ps1",
    "sync:env": "powershell -ExecutionPolicy Bypass -File scripts/check-env-local.ps1",
    "sync:profile": "powershell -ExecutionPolicy Bypass -File scripts/register-sync-profile.ps1 -InstallNow",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
