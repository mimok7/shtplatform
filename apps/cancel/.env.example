# @sht/cancel - 환경 변수

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 단회 토큰 해시에 사용되는 페퍼. Vercel 환경변수에도 동일 값 등록 필요.
CANCEL_TOKEN_PEPPER=

# 매직 링크 회신 URL (예: https://cancel.stayhalong.com)
CANCEL_APP_BASE_URL=https://cancel.stayhalong.com

# 임시 비밀번호 안내 메일에 표시할 일반 로그인 URL
CUSTOMER_APP_URL=https://staycruise.kr

# 임시 비밀번호 발송용 SMTP 설정 (Gmail 등)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
