# DB -> Google Sheets sync settings for /admin/sheets-sync
# Copy these keys to apps/admin/.env.local or your deployment environment.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets target spreadsheet ID
GOOGLE_SHEETS_SPREADSHEET_ID=

# Option A: paste the whole service-account JSON as a single-line value.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B: use split credentials instead of GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=