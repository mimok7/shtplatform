# 홈페이지의 POST /api/platform/sync 전체 URL
HOMEPAGE_SYNC_URL=https://your-homepage-domain.com/api/platform/sync

# 홈페이지 PLATFORM_SYNC_SECRET과 정확히 같은 긴 임의 문자열
HOMEPAGE_SYNC_SECRET=generate-a-long-random-shared-secret

# Vercel Cron이 /api/cron/homepage-sync 호출 시 사용하는 서버 전용 값
CRON_SECRET=generate-a-different-long-random-secret
