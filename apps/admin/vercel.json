{
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ./ ../../packages ../../pnpm-lock.yaml",
  "buildCommand": "cd ../.. && pnpm --filter @sht/admin build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/customer-reminder-cleanup",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/customer-reminder-notifications",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/sht-car-low-seat-warning",
      "schedule": "10 15 * * *"
    },
    {
      "path": "/api/cron/service-missing-fields-notifications",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/payment-notifications-generate",
      "schedule": "0 0 * * *"
    }
  ]
}
