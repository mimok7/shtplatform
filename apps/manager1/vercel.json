{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "ignoreCommand": "cd ../.. && npx turbo-ignore @sht/manager1",
  "buildCommand": "cd ../.. && pnpm --filter @sht/manager1 build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/auto-complete", "schedule": "0 18 * * *" },
    { "path": "/api/cron/daily-stats", "schedule": "0 15 * * *" },
    { "path": "/api/cron/cleanup-documents", "schedule": "0 19 * * *" }
  ]
}
